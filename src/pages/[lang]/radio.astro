---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getLangFromUrl, useTranslations } from '../../i18n/utils'

export async function getStaticPaths() {
	return [{ params: { lang: 'en' } }, { params: { lang: 'pt-br' } }]
}

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const labels = {
	play: t('radio.play'),
	pause: t('radio.pause'),
	coverSuffix: t('radio.coverSuffix'),
}

const playlistOn = t('radio.playlistOn')
const platforms = [
	{ name: 'Spotify', href: 'https://open.spotify.com/playlist/0swsQwFkgSG8RVDTa315lc?si=2708ed80a4a94ca2' },
	{
		name: 'YouTube',
		href: 'https://www.youtube.com/watch?v=3vek0vR60K4&list=PLfI-WbtjGrrt7ZBIjrcpaRCVzQz9rmQXL',
	},
] as const
---

<BaseLayout title={t('radio.title')} description={t('radio.description')} navVariant='radio'>
	<div
		id='radio-page-root'
		data-label-play={labels.play}
		data-label-pause={labels.pause}
		data-label-cover-suffix={labels.coverSuffix}
		class='flex h-[calc(100dvh-4.5rem)] lg:h-[calc(100dvh-10rem)] flex-col items-center justify-center px-4 py-2 sm:py-4'
	>
		<div class='flex w-full max-w-3xl flex-col items-center justify-center text-center gap-3 sm:gap-4'>
			<div class='group relative inline-flex items-center justify-center overflow-visible max-w-full'>
				<div
					id='radio-cover-skeleton'
					aria-hidden='true'
					class='absolute inset-0 z-[1] rounded bg-muted shadow-lg animate-pulse transition-opacity duration-500'
				>
				</div>
				<img
					id='radio-cover'
					src=''
					alt=''
					crossorigin='anonymous'
					class='relative z-[2] h-auto aspect-square w-[min(78vw,420px)] object-cover rounded shadow-lg opacity-0 transition-opacity duration-500'
				/>
				<button
					id='radio-play'
					type='button'
					aria-label={t('radio.play')}
					class='pointer-events-none absolute z-10 top-1/2 left-1/2 inline-flex -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-main bg-main/95 p-3 text-main opacity-0 shadow-lg backdrop-blur-sm transition duration-200 group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:opacity-100 hover:bg-muted focus-visible:pointer-events-auto focus-visible:opacity-100'
				>
					<svg
						id='radio-icon-play'
						xmlns='http://www.w3.org/2000/svg'
						width='24'
						height='24'
						viewBox='0 0 24 24'
						fill='currentColor'
					>
						<path d='M8 5v14l11-7z'></path>
					</svg>
					<svg
						id='radio-icon-pause'
						xmlns='http://www.w3.org/2000/svg'
						width='24'
						height='24'
						viewBox='0 0 24 24'
						fill='currentColor'
						class='hidden'
					>
						<path d='M6 5h4v14H6zM14 5h4v14h-4z'></path>
					</svg>
				</button>
			</div>
			<div class='flex flex-col items-center w-full max-w-xl pt-0 sm:pt-1'>
				<h1
					id='radio-title'
					class='font-bold leading-tight text-[24px] sm:text-[32px] text-balance min-h-[1lh] [text-shadow:0_2px_18px_rgba(0,0,0,0.35)]'
				>
				</h1>
				<div class='mt-3 flex flex-col items-center gap-1 sm:mt-4 sm:gap-[5px]'>
					<p id='radio-artist' class='leading-tight text-[16px] sm:text-[24px] min-h-[1lh]'></p>
					<p class='leading-tight text-[16px] sm:text-[24px] opacity-85 min-h-[1lh]'>
						<em id='radio-album'></em>
					</p>
				</div>
			</div>
		</div>
	</div>

	<section aria-label={playlistOn} class='flex flex-col items-center justify-center px-4 py-10'>
		<div class='flex items-center justify-center gap-10 sm:gap-14'>
			{
				platforms.map(platform => (
					<a
						href={platform.href}
						aria-label={`${playlistOn} ${platform.name}`}
						title={`${playlistOn} ${platform.name}`}
						class='inline-flex items-center justify-center transition-transform duration-200 ease-out hover:scale-110 focus-visible:scale-110'
					>
						{platform.name === 'Spotify' ? (
							<svg
								xmlns='http://www.w3.org/2000/svg'
								viewBox='0 0 24 24'
								fill='currentColor'
								class='h-8 w-8 sm:h-10 sm:w-10'
								aria-hidden='true'
							>
								<path d='M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.78-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.42 1.56-.299.421-1.02.599-1.56.3z' />
							</svg>
						) : (
							<svg
								xmlns='http://www.w3.org/2000/svg'
								viewBox='0 0 24 24'
								fill='currentColor'
								class='h-8 w-8 sm:h-10 sm:w-10'
								aria-hidden='true'
							>
								<path d='M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z' />
							</svg>
						)}
					</a>
				))
			}
		</div>
	</section>

	<style is:inline>
		.show-radio-controls > #radio-play {
			opacity: 1;
			pointer-events: auto;
		}
	</style>

	<script>
		import { getRadioPlayer } from '../../lib/radio-player'
		import { mount } from '../../lib/ambient-glow'

		const RADIO_API = import.meta.env.PUBLIC_RADIO_API_URL

		document.addEventListener('astro:page-load', () => {
			const root = document.getElementById('radio-page-root')
			const audio = document.getElementById('radio-audio') as HTMLAudioElement | null
			if (!root || !audio) return

			const labelPlay = root.dataset.labelPlay || 'Play'
			const labelPause = root.dataset.labelPause || 'Pause'
			const labelCoverSuffix = root.dataset.labelCoverSuffix || ''

			const player = getRadioPlayer(audio, RADIO_API)

			const playBtn = document.getElementById('radio-play')!
			const iconPlay = document.getElementById('radio-icon-play')!
			const iconPause = document.getElementById('radio-icon-pause')!
			const coverEl = document.getElementById('radio-cover') as HTMLImageElement
			const coverFrameEl = coverEl.parentElement!
			const skeletonEl = document.getElementById('radio-cover-skeleton')!
			const titleEl = document.getElementById('radio-title')!
			const artistEl = document.getElementById('radio-artist')!
			const albumEl = document.getElementById('radio-album')!

			const faviconEl = document.querySelector<HTMLLinkElement>('link[rel="icon"]')
			const originalTitle = document.title
			const originalFavicon = faviconEl?.getAttribute('href') ?? null
			const originalFaviconType = faviconEl?.getAttribute('type') ?? null

			let controlsVisibleTimer: ReturnType<typeof setTimeout> | null = null

			function showControlsTemporarily() {
				coverFrameEl.classList.add('show-radio-controls')
				playBtn.classList.remove('pointer-events-none')
				playBtn.classList.add('pointer-events-auto')

				if (controlsVisibleTimer) clearTimeout(controlsVisibleTimer)

				controlsVisibleTimer = setTimeout(() => {
					coverFrameEl.classList.remove('show-radio-controls')
					playBtn.classList.add('pointer-events-none')
					playBtn.classList.remove('pointer-events-auto')
					controlsVisibleTimer = null
				}, 2500)
			}

			const controller = new AbortController()
			const { signal } = controller

			playBtn.addEventListener('click', () => player.toggle(), { signal })
			coverEl.addEventListener('dblclick', () => player.toggle(), { signal })
			coverEl.addEventListener('click', showControlsTemporarily, { signal })

			const revealCover = () => {
				coverEl.classList.remove('opacity-0')
				skeletonEl.classList.add('opacity-0')
			}
			coverEl.addEventListener('load', revealCover, { signal })
			if (coverEl.complete && coverEl.naturalWidth) revealCover()

			const unsubscribe = player.subscribe(state => {
				const track = state.track
				titleEl.textContent = track?.title || ''
				artistEl.textContent = track?.artist || ''
				albumEl.textContent = track?.album || ''
				const cover = track?.albumArtUrl || track?.coverUrl || ''
				if (cover && coverEl.src !== cover) {
					coverEl.src = cover
					coverEl.alt = track?.title ? `${track.title} ${labelCoverSuffix}` : ''
				}

				if (track?.title) {
					document.title = track.artist ? `${track.title} — ${track.artist}` : track.title
				} else {
					document.title = originalTitle
				}

				if (faviconEl && cover && faviconEl.getAttribute('href') !== cover) {
					faviconEl.setAttribute('href', cover)
					faviconEl.removeAttribute('type')
				}

				const showingPlaying = state.wantPlaying
				playBtn.setAttribute('aria-label', showingPlaying ? labelPause : labelPlay)
				iconPlay.classList.toggle('hidden', showingPlaying)
				iconPause.classList.toggle('hidden', !showingPlaying)
			})

			const glow = mount(coverEl, {
				binSize: 64,
				gridSize: 5,
				blur: 56,
				sizeMultiplier: 2.05,
				majorBlobCount: 5,
				majorBlobOpacity: 0.8,
				majorBlobRadius: 30,
				majorBlobFeather: 74,
				jitter: 22,
				edgeBleed: 30,
				horizontalStretch: 1.5,
				verticalStretch: 1.18,
				sideBloomCount: 2,
				sideBloomOpacity: 0.34,
				sideBloomRadius: 48,
			})

			document.addEventListener(
				'astro:before-preparation',
				() => {
					if (controlsVisibleTimer) clearTimeout(controlsVisibleTimer)
					unsubscribe()
					controller.abort()
					glow.destroy()
					document.title = originalTitle
					if (faviconEl) {
						if (originalFavicon) faviconEl.setAttribute('href', originalFavicon)
						else faviconEl.removeAttribute('href')
						if (originalFaviconType) faviconEl.setAttribute('type', originalFaviconType)
					}
				},
				{ once: true },
			)
		})
	</script>
</BaseLayout>

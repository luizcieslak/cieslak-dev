---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getLangFromUrl, useTranslations } from '../../i18n/utils'

export async function getStaticPaths() {
	return [{ params: { lang: 'en' } }, { params: { lang: 'pt-br' } }]
}

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const RADIO_API = import.meta.env.PUBLIC_RADIO_API_URL
const labels = {
	play: t('radio.play'),
	pause: t('radio.pause'),
	coverSuffix: t('radio.coverSuffix'),
}
---

<BaseLayout title={t('radio.title')} description={t('radio.description')} navVariant='radio'>
	<div class='flex h-[calc(100dvh-4.5rem)] flex-col items-center justify-center px-4 py-2 sm:py-4'>
		<div class='flex w-full max-w-3xl flex-col items-center justify-center text-center gap-3 sm:gap-4'>
			<div class='group relative inline-flex items-center justify-center'>
				<img
					id='radio-cover'
					src=''
					alt=''
					crossorigin='anonymous'
					class='relative z-[1] w-[78vw] h-[78vw] max-w-full sm:w-[420px] sm:h-[420px] object-cover rounded shadow-lg bg-muted'
				/>
				<button
					id='radio-play'
					type='button'
					aria-label={t('radio.play')}
					class='pointer-events-none absolute z-10 top-3 left-1/2 inline-flex -translate-x-1/2 items-center justify-center rounded-full border border-main bg-main/95 p-3 text-main opacity-0 shadow-lg backdrop-blur-sm transition duration-200 group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:opacity-100 hover:bg-muted focus-visible:pointer-events-auto focus-visible:opacity-100'
				>
					<svg
						id='radio-icon-play'
						xmlns='http://www.w3.org/2000/svg'
						width='24'
						height='24'
						viewBox='0 0 24 24'
						fill='currentColor'
					>
						<path d='M8 5v14l11-7z'></path>
					</svg>
					<svg
						id='radio-icon-pause'
						xmlns='http://www.w3.org/2000/svg'
						width='24'
						height='24'
						viewBox='0 0 24 24'
						fill='currentColor'
						class='hidden'
					>
						<path d='M6 5h4v14H6zM14 5h4v14h-4z'></path>
					</svg>
				</button>
			</div>
			<div class='flex flex-col items-center w-full max-w-xl pt-0 sm:pt-1'>
				<h1
					id='radio-title'
					class='font-bold leading-tight text-[24px] sm:text-[32px] text-balance [text-shadow:0_2px_18px_rgba(0,0,0,0.35)]'
				>
				</h1>
				<div class='mt-3 flex flex-col items-center gap-1 sm:mt-4 sm:gap-[5px]'>
					<p id='radio-artist' class='leading-tight text-[16px] sm:text-[24px]'></p>
					<p class='leading-tight text-[16px] sm:text-[24px] opacity-85'>
						<em id='radio-album'></em>
					</p>
				</div>
			</div>
		</div>
	</div>

	<audio id='radio-audio' preload='none'></audio>

	<script is:inline define:vars={{ RADIO_API, labels }}>
		document.addEventListener('astro:page-load', () => {
			const audio = document.getElementById('radio-audio')
			if (!audio) return

			const playBtn = document.getElementById('radio-play')
			const iconPlay = document.getElementById('radio-icon-play')
			const iconPause = document.getElementById('radio-icon-pause')
			const coverEl = document.getElementById('radio-cover')
			const coverFrameEl = coverEl.parentElement
			const titleEl = document.getElementById('radio-title')
			const artistEl = document.getElementById('radio-artist')
			const albumEl = document.getElementById('radio-album')

			audio.volume = 0.7

			let wantPlaying = false
			let reconnectAttempt = 0
			let reconnectTimer = null
			let wakeLock = null
			let controlsVisibleTimer = null
			const BASE_BACKOFF_MS = 1000
			const MAX_BACKOFF_MS = 30000

			function setTrack(track) {
				if (!track) return
				titleEl.textContent = track.title || ''
				artistEl.textContent = track.artist || ''
				albumEl.textContent = track.album || ''
				const cover = track.albumArtUrl || track.coverUrl
				if (cover) {
					coverEl.src = cover
					coverEl.alt = track.title ? track.title + ' ' + labels.coverSuffix : ''
				}
			}

			function renderPlayState(playing) {
				playBtn.setAttribute('aria-label', playing ? labels.pause : labels.play)
				iconPlay.classList.toggle('hidden', playing)
				iconPause.classList.toggle('hidden', !playing)
			}

			function showControlsTemporarily() {
				if (!coverFrameEl) return
				coverFrameEl.classList.add('show-radio-controls')
				playBtn.classList.remove('pointer-events-none')
				playBtn.classList.add('pointer-events-auto')

				if (controlsVisibleTimer) {
					clearTimeout(controlsVisibleTimer)
				}

				controlsVisibleTimer = setTimeout(() => {
					coverFrameEl.classList.remove('show-radio-controls')
					playBtn.classList.add('pointer-events-none')
					playBtn.classList.remove('pointer-events-auto')
					controlsVisibleTimer = null
				}, 2500)
			}

			async function requestWakeLock() {
				if (!wantPlaying || !('wakeLock' in navigator) || wakeLock) return

				try {
					wakeLock = await navigator.wakeLock.request('screen')
					wakeLock.addEventListener('release', () => {
						wakeLock = null
					})
				} catch {}
			}

			async function releaseWakeLock() {
				if (!wakeLock) return

				const lock = wakeLock
				wakeLock = null
				await lock.release().catch(() => {})
			}

			function connect() {
				clearTimeout(reconnectTimer)
				reconnectTimer = null
				audio.src = RADIO_API + '/stream?t=' + Date.now()
				audio.play().catch(() => scheduleReconnect())
			}

			function scheduleReconnect() {
				if (!wantPlaying || reconnectTimer) return
				const delay = Math.min(BASE_BACKOFF_MS * Math.pow(1.5, reconnectAttempt), MAX_BACKOFF_MS)
				reconnectAttempt++
				reconnectTimer = setTimeout(connect, delay)
			}

			function stop() {
				wantPlaying = false
				clearTimeout(reconnectTimer)
				reconnectTimer = null
				reconnectAttempt = 0
				void releaseWakeLock()
				audio.pause()
				audio.removeAttribute('src')
				audio.load()
			}

			function togglePlayback() {
				if (!wantPlaying) {
					wantPlaying = true
					void requestWakeLock()
					connect()
					return
				}

				stop()
			}

			const controller = new AbortController()
			const signal = controller.signal

			fetch(RADIO_API + '/now-playing', { signal })
				.then(r => r.json())
				.then(data => setTrack(data && data.track))
				.catch(() => {})

			const events = new EventSource(RADIO_API + '/now-playing/events')
			events.onmessage = ev => {
				try {
					const data = JSON.parse(ev.data)
					setTrack(data.track || data)
				} catch {}
			}

			playBtn.addEventListener('click', togglePlayback, { signal })
			coverEl.addEventListener('dblclick', togglePlayback, { signal })
			coverEl.addEventListener('click', showControlsTemporarily, { signal })

			audio.addEventListener(
				'play',
				() => {
					reconnectAttempt = 0
					void requestWakeLock()
					renderPlayState(true)
				},
				{ signal },
			)

			audio.addEventListener(
				'pause',
				() => {
					renderPlayState(false)
					if (wantPlaying) scheduleReconnect()
				},
				{ signal },
			)

			audio.addEventListener('ended', () => scheduleReconnect(), { signal })
			audio.addEventListener('error', () => scheduleReconnect(), { signal })
			audio.addEventListener('stalled', () => scheduleReconnect(), { signal })

			document.addEventListener(
				'visibilitychange',
				() => {
					if (!wantPlaying) return
					if (document.visibilityState === 'visible') {
						void requestWakeLock()
					}
				},
				{ signal },
			)

			document.addEventListener(
				'astro:before-preparation',
				() => {
					wantPlaying = false
					clearTimeout(reconnectTimer)
					if (controlsVisibleTimer) {
						clearTimeout(controlsVisibleTimer)
					}
					void releaseWakeLock()
					events.close()
					audio.pause()
					audio.removeAttribute('src')
					audio.load()
					controller.abort()
				},
				{ once: true },
			)
		})
	</script>

	<style is:inline>
		.show-radio-controls > #radio-play {
			opacity: 1;
			pointer-events: auto;
		}
	</style>

	<script>
		import { mount } from '../../lib/ambient-glow'

		document.addEventListener('astro:page-load', () => {
			const img = document.getElementById('radio-cover') as HTMLImageElement | null
			if (!img) return

			const handle = mount(img, {
				binSize: 64,
				gridSize: 5,
				blur: 56,
				sizeMultiplier: 2.05,
				majorBlobCount: 5,
				majorBlobOpacity: 0.8,
				majorBlobRadius: 30,
				majorBlobFeather: 74,
				jitter: 22,
				edgeBleed: 30,
				horizontalStretch: 1.5,
				verticalStretch: 1.18,
				sideBloomCount: 2,
				sideBloomOpacity: 0.34,
				sideBloomRadius: 48,
			})

			document.addEventListener('astro:before-preparation', () => handle.destroy(), { once: true })
		})
	</script>
</BaseLayout>

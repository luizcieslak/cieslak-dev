---
type Lang = 'en' | 'pt-br'

interface Props {
	lang?: Lang
}

const { lang = 'en' } = Astro.props

const strings = {
	en: {
		frameTpl: 'frame {n}/{N} · everyone on the same frame',
		broadcast: 'broadcast',
		listener: 'listener',
		tag: 'joined mid-song',
	},
	'pt-br': {
		frameTpl: 'frame {n}/{N} · todos no mesmo frame',
		broadcast: 'transmissão',
		listener: 'ouvinte',
		tag: 'entrou no meio',
	},
}[lang]

const listeners = [
	{ n: 1, join: 0, late: false },
	{ n: 2, join: 0, late: false },
	{ n: 3, join: 0.44, late: true },
	{ n: 4, join: 0.71, late: true },
]

const rows = [
	{ key: 'broadcast', label: strings.broadcast, kind: 'broadcast', join: 0, late: false },
	...listeners.map(l => ({ key: `l${l.n}`, label: `${strings.listener} ${l.n}`, kind: 'listener', join: l.join, late: l.late })),
]
---

<figure
	class='fanout-demo not-prose my-10 rounded-lg border border-main/20 bg-muted/30 p-4 sm:p-6'
	data-frame-tpl={strings.frameTpl}
	data-frames='240'
>
	<figcaption class='mb-4 text-sm leading-relaxed opacity-80'>
		{
			lang === 'en' ? (
				<>
					One frame goes out every <span class='font-mono'>26&nbsp;ms</span> to <em>every</em> listener at once.
					Tune in late and the song doesn't restart — you join right where it is now, exactly like a radio.
				</>
			) : (
				<>
					Um frame sai a cada <span class='font-mono'>26&nbsp;ms</span> para <em>todos</em> os ouvintes ao mesmo
					tempo. Se você chega atrasado, a música não recomeça — você entra exatamente onde ela está agora, igual a
					um rádio.
				</>
			)
		}
	</figcaption>

	<div class='fanout-stage grid items-center gap-x-3 gap-y-2' style='grid-template-columns: max-content 1fr;'>
		{
			rows.map(row => (
				<Fragment>
					<div class='fanout-label text-right leading-tight transition-opacity duration-300'>
						<div class='font-mono text-xs sm:text-sm'>{row.label}</div>
						{row.late && (
							<div class='fanout-tag text-[10px] text-amber-600 opacity-0 transition-opacity duration-300 dark:text-amber-400'>
								{strings.tag}
							</div>
						)}
					</div>
					<div
						class='fanout-track relative h-7 overflow-hidden rounded-md bg-black/[0.03] ring-1 ring-inset ring-black/5 dark:bg-white/[0.04] dark:ring-white/10 sm:h-8'
						data-row={row.key}
						data-kind={row.kind}
						data-join={row.join}
						data-late={String(row.late)}
					/>
				</Fragment>
			))
		}
	</div>

	<p class='fanout-frame mt-4 font-mono text-xs tabular-nums opacity-60 sm:text-sm'></p>
</figure>

<style is:global>
	@keyframes fanout-pulse {
		0%,
		100% {
			transform: translate(-50%, -50%) scale(1);
			opacity: 1;
		}
		50% {
			transform: translate(-50%, -50%) scale(1.7);
			opacity: 0.45;
		}
	}
</style>

<script>
	const CYCLE_MS = 7000
	const HOLD_MS = 1300

	interface Row {
		kind: string
		join: number
		late: boolean
		label: HTMLElement
		tag: HTMLElement | null
		missed: HTMLElement | null
		fill: HTMLElement
		now: HTMLElement
	}

	function buildRow(track: HTMLElement, labelCell: HTMLElement): Row {
		const kind = track.dataset.kind ?? 'listener'
		const join = parseFloat(track.dataset.join ?? '0')
		const late = track.dataset.late === 'true'

		let missed: HTMLElement | null = null
		if (join > 0) {
			missed = document.createElement('div')
			missed.className = 'absolute inset-y-1 rounded-sm text-black/20 dark:text-white/25'
			missed.style.backgroundImage =
				'repeating-linear-gradient(45deg, currentColor 0, currentColor 1px, transparent 1px, transparent 5px)'
			track.appendChild(missed)
		}

		const fill = document.createElement('div')
		fill.className =
			kind === 'broadcast'
				? 'absolute inset-y-1 rounded-sm bg-black/35 dark:bg-white/35'
				: 'absolute inset-y-1 rounded-sm bg-emerald-500/80'
		track.appendChild(fill)

		const now = document.createElement('div')
		now.className = 'absolute inset-y-0 w-0.5 -translate-x-1/2 rounded bg-black/55 dark:bg-white/70'
		if (kind === 'broadcast') {
			const dot = document.createElement('div')
			dot.className = 'absolute left-1/2 top-0 h-2 w-2 rounded-full bg-amber-500'
			dot.style.animation = 'fanout-pulse 1.1s ease-in-out infinite'
			now.appendChild(dot)
		}
		track.appendChild(now)

		return { kind, join, late, label: labelCell, tag: labelCell.querySelector('.fanout-tag'), missed, fill, now }
	}

	function initDemo(root: HTMLElement): () => void {
		const frameTpl = root.dataset.frameTpl ?? 'frame {n}/{N}'
		const N = parseInt(root.dataset.frames ?? '240', 10)
		const frameEl = root.querySelector<HTMLElement>('.fanout-frame')!

		const tracks = Array.from(root.querySelectorAll<HTMLElement>('.fanout-track'))
		const labels = Array.from(root.querySelectorAll<HTMLElement>('.fanout-label'))
		const rows = tracks.map((track, i) => buildRow(track, labels[i]))

		function update(f: number) {
			frameEl.textContent = frameTpl.replace('{n}', String(Math.round(f * N))).replace('{N}', String(N))
			for (const row of rows) {
				const connected = row.kind === 'broadcast' || f >= row.join
				const left = row.join
				const width = connected ? Math.max(0, f - left) : 0
				row.fill.style.left = `${left * 100}%`
				row.fill.style.width = `${width * 100}%`
				if (row.missed) row.missed.style.cssText += `;left:0%;width:${connected ? row.join * 100 : 0}%`
				row.now.style.left = `${f * 100}%`
				row.label.classList.toggle('opacity-40', !connected)
				if (row.tag) row.tag.style.opacity = connected && row.late ? '1' : '0'
			}
		}

		if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
			update(0.82)
			return () => {}
		}

		let cycleStart = 0
		let holdUntil = 0
		let phase: 'play' | 'hold' = 'play'
		let raf = 0
		let running = false

		function loop(now: number) {
			if (phase === 'play') {
				const f = (now - cycleStart) / CYCLE_MS
				if (f >= 1) {
					update(1)
					phase = 'hold'
					holdUntil = now + HOLD_MS
				} else {
					update(f)
				}
			} else if (now >= holdUntil) {
				cycleStart = now
				phase = 'play'
				update(0)
			}
			raf = requestAnimationFrame(loop)
		}

		function start() {
			if (running) return
			running = true
			cycleStart = performance.now()
			phase = 'play'
			update(0)
			raf = requestAnimationFrame(loop)
		}

		function stop() {
			running = false
			cancelAnimationFrame(raf)
		}

		const io = new IntersectionObserver(
			entries => {
				for (const e of entries) {
					if (e.isIntersecting) start()
					else stop()
				}
			},
			{ threshold: 0.2 },
		)
		io.observe(root)

		return () => {
			stop()
			io.disconnect()
		}
	}

	document.addEventListener('astro:page-load', () => {
		const roots = document.querySelectorAll<HTMLElement>('.fanout-demo')
		if (roots.length === 0) return

		const cleanups = Array.from(roots, initDemo)

		document.addEventListener('astro:before-preparation', () => cleanups.forEach(fn => fn()), { once: true })
	})
</script>

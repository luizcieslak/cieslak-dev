---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const labelPlay = t('radio.play')
const labelPause = t('radio.pause')
---

<aside
	class='radio-callout my-10 mx-auto flex w-max min-w-[230px] items-center rounded-lg border border-main/20 bg-muted/40 px-3 py-2 not-prose'
	data-label-play={labelPlay}
	data-label-pause={labelPause}
>
	<button
		class='radio-callout-toggle relative z-[2] inline-flex h-12 w-12 flex-none items-center justify-center rounded-full border border-main bg-main/95 text-main shadow-sm transition hover:bg-muted'
		type='button'
		aria-label={labelPlay}
	>
		<svg
			class='radio-callout-icon-play'
			xmlns='http://www.w3.org/2000/svg'
			width='22'
			height='22'
			viewBox='0 0 24 24'
			fill='currentColor'
		>
			<path d='M8 5v14l11-7z'></path>
		</svg>
		<svg
			class='radio-callout-icon-pause hidden'
			xmlns='http://www.w3.org/2000/svg'
			width='22'
			height='22'
			viewBox='0 0 24 24'
			fill='currentColor'
		>
			<path d='M6 5h4v14H6zM14 5h4v14h-4z'></path>
		</svg>
	</button>
	<div class='radio-callout-now-playing flex min-w-0 items-center gap-3'>
		<span class='radio-callout-cover-frame relative flex-none h-12 w-12'>
			<img
				class='radio-callout-track-cover relative z-[1] block h-full w-full rounded bg-muted object-cover'
				src=''
				alt=''
				crossorigin='anonymous'
			/>
		</span>
		<div class='min-w-0 flex-1'>
			<p class='radio-callout-track-title truncate text-sm font-medium leading-tight'></p>
			<p class='radio-callout-track-artist truncate text-xs leading-tight opacity-70'></p>
		</div>
	</div>
</aside>

<style is:inline>
	.radio-callout-now-playing {
		max-width: 0;
		opacity: 0;
		padding-left: 0;
		overflow: hidden;
		transition:
			max-width 500ms cubic-bezier(0.4, 0, 0.2, 1),
			opacity 350ms ease,
			padding-left 500ms cubic-bezier(0.4, 0, 0.2, 1);
	}
	.radio-callout[data-has-track='true'] .radio-callout-now-playing {
		max-width: 320px;
		opacity: 1;
		padding-left: 0.75rem;
	}
</style>

<script>
	import { getRadioPlayer } from '../lib/radio-player'
	import { mount } from '../lib/ambient-glow'

	const RADIO_API = import.meta.env.PUBLIC_RADIO_API_URL

	document.addEventListener('astro:page-load', () => {
		const callouts = document.querySelectorAll<HTMLElement>('.radio-callout')
		if (callouts.length === 0) return

		const audio = document.getElementById('radio-audio') as HTMLAudioElement | null
		if (!audio) return

		const player = getRadioPlayer(audio, RADIO_API)

		const inViewState = new WeakMap<Element, boolean>()
		const observer = new IntersectionObserver(
			entries => {
				for (const entry of entries) {
					const wasInView = inViewState.get(entry.target) === true
					const isInView = entry.isIntersecting
					if (wasInView === isInView) continue
					inViewState.set(entry.target, isInView)
					window.__radioMiniplayerCalloutDelta?.(isInView ? 1 : -1)
				}
			},
			{ rootMargin: '-40px 0px' },
		)

		document.addEventListener(
			'astro:before-preparation',
			() => {
				for (const callout of callouts) {
					if (inViewState.get(callout) === true) {
						window.__radioMiniplayerCalloutDelta?.(-1)
					}
				}
				observer.disconnect()
			},
			{ once: true },
		)

		callouts.forEach(callout => {
			observer.observe(callout)
			const labelPlay = callout.dataset.labelPlay || 'Play'
			const labelPause = callout.dataset.labelPause || 'Pause'
			const toggleBtn = callout.querySelector<HTMLButtonElement>('.radio-callout-toggle')!
			const iconPlay = callout.querySelector<SVGElement>('.radio-callout-icon-play')!
			const iconPause = callout.querySelector<SVGElement>('.radio-callout-icon-pause')!
			const titleEl = callout.querySelector<HTMLElement>('.radio-callout-track-title')!
			const artistEl = callout.querySelector<HTMLElement>('.radio-callout-track-artist')!
			const coverEl = callout.querySelector<HTMLImageElement>('.radio-callout-track-cover')!

			const glow = mount(coverEl, {
				blur: 10,
				sizeMultiplier: 3.8,
				majorBlobCount: 4,
				majorBlobOpacity: 0.65,
				majorBlobRadius: 32,
				majorBlobFeather: 72,
				jitter: 16,
				edgeBleed: 26,
				horizontalStretch: 1.45,
				verticalStretch: 1.1,
				sideBloomCount: 2,
				sideBloomOpacity: 0.32,
				sideBloomRadius: 42,
			})

			const controller = new AbortController()
			const { signal } = controller

			toggleBtn.addEventListener('click', () => player.toggle(), { signal })

			const unsubscribe = player.subscribe(state => {
				const playing = state.wantPlaying
				toggleBtn.setAttribute('aria-label', playing ? labelPause : labelPlay)
				iconPlay.classList.toggle('hidden', playing)
				iconPause.classList.toggle('hidden', !playing)

				const track = state.track
				if (playing && track) {
					titleEl.textContent = track.title || ''
					artistEl.textContent = track.artist || ''
					const cover = track.albumArtUrl || track.coverUrl || ''
					if (cover && coverEl.src !== cover) {
						coverEl.src = cover
						coverEl.alt = track.title || ''
					}
					callout.dataset.hasTrack = 'true'
				} else {
					callout.dataset.hasTrack = 'false'
				}
			})

			document.addEventListener(
				'astro:before-preparation',
				() => {
					unsubscribe()
					controller.abort()
					glow.destroy()
				},
				{ once: true },
			)
		})
	})
</script>

---
interface Props {
	defaultImage?: string
	defaultAlt?: string
}

const { defaultImage = '/lofi/lofi.png', defaultAlt = 'Color palette extraction preview' } = Astro.props
---

<figure class='ambient-palette-sandbox not-prose my-10 rounded-lg border border-main/20 bg-muted/30 p-4'>
	<div class='grid gap-5 sm:grid-cols-[1fr,1fr] sm:items-center'>
		<img
			class='ambient-palette-sandbox-img block aspect-square w-full rounded-md object-cover shadow-md'
			src={defaultImage}
			alt={defaultAlt}
			crossorigin='anonymous'
		/>
		<div class='ambient-palette-sandbox-grid grid aspect-square w-full overflow-hidden rounded-md'>
			<!-- swatches injected by <script> below -->
		</div>
	</div>

	<div class='mt-5 grid gap-3 text-sm'>
		<label class='flex items-center gap-3'>
			<span class='w-32 shrink-0 opacity-80'>Grid size</span>
			<input
				class='ambient-palette-sandbox-grid-size flex-1'
				type='range'
				min='2'
				max='60'
				step='1'
				value='4'
			/>
			<output class='ambient-palette-sandbox-grid-size-out w-14 text-right tabular-nums opacity-70'
				>4×4</output
			>
		</label>
		<label class='flex items-center gap-3'>
			<span class='w-32 shrink-0 opacity-80'>Upload image</span>
			<input class='ambient-palette-sandbox-upload flex-1' type='file' accept='image/*' />
		</label>
	</div>
</figure>

<script>
	import { extractColors, type Rgb } from '../lib/ambient-glow'

	function rgbToHex({ r, g, b }: Rgb): string {
		const h = (n: number) => n.toString(16).padStart(2, '0')
		return `#${h(r)}${h(g)}${h(b)}`
	}

	function render(host: HTMLElement, colors: Array<Rgb | null>, gridSize: number) {
		host.style.gridTemplateColumns = `repeat(${gridSize}, minmax(0, 1fr))`
		host.style.gridTemplateRows = `repeat(${gridSize}, minmax(0, 1fr))`
		host.innerHTML = ''
		const showLabel = gridSize <= 6
		colors.forEach(color => {
			const cell = document.createElement('div')
			cell.className = 'relative flex items-end justify-center'
			if (color) {
				const hex = rgbToHex(color)
				cell.style.background = hex
				cell.innerHTML = showLabel
					? `<span class="m-1 rounded bg-black/60 px-1.5 py-0.5 text-[10px] font-mono leading-none text-white">${hex}</span>`
					: ''
			} else {
				cell.style.background = 'transparent'
				cell.innerHTML = showLabel ? '<span class="m-1 text-[10px] opacity-50">—</span>' : ''
			}
			host.appendChild(cell)
		})
	}

	document.addEventListener('astro:page-load', () => {
		const roots = document.querySelectorAll<HTMLElement>('.ambient-palette-sandbox')
		if (roots.length === 0) return

		const cleanups: Array<() => void> = []

		roots.forEach(root => {
			const img = root.querySelector<HTMLImageElement>('.ambient-palette-sandbox-img')!
			const host = root.querySelector<HTMLElement>('.ambient-palette-sandbox-grid')!
			const upload = root.querySelector<HTMLInputElement>('.ambient-palette-sandbox-upload')!
			const gridSizeInput = root.querySelector<HTMLInputElement>('.ambient-palette-sandbox-grid-size')!
			const gridSizeOut = root.querySelector<HTMLElement>('.ambient-palette-sandbox-grid-size-out')!

			const update = () => {
				const gridSize = parseInt(gridSizeInput.value, 10)
				gridSizeOut.textContent = `${gridSize}×${gridSize}`
				const colors = extractColors(img, { gridSize })
				render(host, colors, gridSize)
			}

			const controller = new AbortController()
			const { signal } = controller

			img.addEventListener('load', update, { signal })
			gridSizeInput.addEventListener('input', update, { signal })
			if (img.complete && img.naturalWidth) update()

			let lastObjectUrl: string | null = null
			upload.addEventListener(
				'change',
				() => {
					const file = upload.files?.[0]
					if (!file) return
					if (lastObjectUrl) URL.revokeObjectURL(lastObjectUrl)
					lastObjectUrl = URL.createObjectURL(file)
					img.removeAttribute('crossorigin')
					img.src = lastObjectUrl
				},
				{ signal },
			)

			cleanups.push(() => {
				controller.abort()
				if (lastObjectUrl) URL.revokeObjectURL(lastObjectUrl)
			})
		})

		document.addEventListener(
			'astro:before-preparation',
			() => {
				cleanups.forEach(fn => fn())
			},
			{ once: true },
		)
	})
</script>
